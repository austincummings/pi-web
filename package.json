{
    "name": "pi-web",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "description": "Self-modifiable web UI for the pi coding agent",
    "scripts": {
        "start": "bun run src/host/server.ts",
        "dev": "PI_WEB_DEV=1 bun --watch src/host/server.ts",
        "build": "bun build src/web/app.ts --target=browser --outdir dist",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "bun test"
    },
    "engines": {
        "bun": ">=1.3.0"
    },
    "dependencies": {
        "@earendil-works/pi-coding-agent": "0.80.2",
        "diff": "^8.0.4"
    },
    "devDependencies": {
        "@types/bun": "^1.3.0",
        "prettier": "^3.9.4",
        "typescript": "^5.7.0"
    }
}
